<UserControl x:Class="Trita.Views.NhatKyThiCong.NhatKyThiCongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style x:Key="InputBox" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style x:Key="TableHeaderCell" TargetType="Border">
            <Setter Property="Background" Value="#5B8C3A"/>
            <Setter Property="Padding" Value="4,6"/>
        </Style>
        <Style x:Key="DetailSectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER: THÔNG TIN NGÀY ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,10"
                Margin="0,0,0,12">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,4">
                    <TextBlock Text="Dự án:" Style="{StaticResource HeaderLabel}" Margin="0,0,6,0"/>
                    <Border Style="{StaticResource InputBox}" Width="180">
                        <TextBox x:Name="DuAnTextBox" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,4">
                    <TextBlock Text="Địa điểm:" Style="{StaticResource HeaderLabel}" Margin="0,0,6,0"/>
                    <Border Style="{StaticResource InputBox}" Width="180">
                        <TextBox x:Name="DiaDiemTextBox" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,4">
                    <TextBlock Text="Ngày:" Style="{StaticResource HeaderLabel}" Margin="0,0,6,0"/>
                    <Border Style="{StaticResource InputBox}" Width="120" Padding="4,0">
                        <DatePicker x:Name="NgayPicker" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,4">
                    <TextBlock Text="Thời tiết buổi sáng:" Style="{StaticResource HeaderLabel}" Margin="0,0,6,0"/>
                    <Border Style="{StaticResource InputBox}" Width="100">
                        <TextBox x:Name="ThoiTietSangTextBox" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Thời tiết buổi chiều:" Style="{StaticResource HeaderLabel}" Margin="0,0,6,0"/>
                    <Border Style="{StaticResource InputBox}" Width="100">
                        <TextBox x:Name="ThoiTietChieuTextBox" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ===== PHẦN GIỮA: BẢNG + CHI TIẾT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI: BẢNG CÔNG TÁC CHI TIẾT -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Công tác chi tiết"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <!-- Header bảng -->
                    <Border Grid.Row="1" CornerRadius="8,8,0,0" ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 headers -->
                            <Border Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="STT" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                            </Border>
                            <Border Grid.Column="1" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="Hạng mục" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                            <Border Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="Công việc" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                            <Border Grid.Column="3" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="Lý trình" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                            </Border>

                            <!-- Thực hiện - span 2 cột -->
                            <Border Grid.Column="4" Grid.ColumnSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="Thực hiện" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontSize="11"/>
                            </Border>
                            <Border Grid.Column="4" Grid.Row="1" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0" Padding="2,4">
                                <TextBlock Text="Đơn vị" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontSize="10"/>
                            </Border>
                            <Border Grid.Column="5" Grid.Row="1" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0" Padding="2,4">
                                <TextBlock Text="Khối lượng" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontSize="10" TextWrapping="Wrap"/>
                            </Border>

                            <Border Grid.Column="6" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="Tiến độ %" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10" TextWrapping="Wrap"/>
                            </Border>
                            <Border Grid.Column="7" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}" BorderBrush="#4A7A2A" BorderThickness="0,0,1,0">
                                <TextBlock Text="Máy móc/TB" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10" TextWrapping="Wrap"/>
                            </Border>
                            <Border Grid.Column="8" Grid.RowSpan="2" Style="{StaticResource TableHeaderCell}">
                                <TextBlock Text="Vật liệu" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Dữ liệu bảng -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BangCongTacPanel"/>
                    </ScrollViewer>

                    <!-- Nút thêm dòng -->
                    <Button Grid.Row="3"
                            Content="[+]  Thêm công tác"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#5B8C3A"
                            FontWeight="Bold"
                            FontStyle="Italic"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Click="ThemCongTac_Click"/>
                </Grid>
            </Border>

            <!-- CỘT PHẢI: CHI TIẾT CÔNG TÁC -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <!-- Header xanh -->
                    <Border VerticalAlignment="Top"
                            Background="#3A7BD5"
                            CornerRadius="12,12,0,0"
                            Padding="16,10">
                        <TextBlock Text="Chi tiết công tác"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Margin="0,46,0,0" Padding="16,10" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChiTietCongTacPanel">
                            <TextBlock Text="← Chọn một công tác để xem chi tiết"
                                       FontStyle="Italic"
                                       Foreground="Gray"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== PHẦN DƯỚI: BIỂU ĐỒ ===== -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Biểu đồ Vật liệu -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Vật liệu" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Canvas x:Name="BieuDoVatLieu" Width="120" Height="120"/>
                    <StackPanel x:Name="ChuThichVatLieu" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Biểu đồ Máy móc -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Máy móc/Thiết bị" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Canvas x:Name="BieuDoMayMoc" Width="120" Height="120"/>
                    <StackPanel x:Name="ChuThichMayMoc" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Biểu đồ Nhân lực -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Nhân lực" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Canvas x:Name="BieuDoNhanLuc" Width="120" Height="120"/>
                    <StackPanel x:Name="ChuThichNhanLuc" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
