<Window x:Class="Trita.Views.NhatKyThiCong.NhanLucPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Khai báo nhân lực"
        Width="460" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>

        <!-- Label pill xám -->
        <Style x:Key="LabelPill" TargetType="Border">
            <Setter Property="Background"      Value="#E6E6E6"/>
            <Setter Property="BorderBrush"     Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="20"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="16,0"/>
        </Style>

        <!-- TextBox pill trắng — template tự bo tròn, không cần Border ngoài -->
        <Style x:Key="PillTextBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="40"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#CCCCCC"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3A7BD5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button bo tròn -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28,10,28,17">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="41.28"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="56"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0"
                   Text="KHAI BÁO NHÂN LỰC"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#2E4057"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20" Width="166"/>

        <!-- Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Height="216">

            <!-- Số lượng nhân công -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="Số lượng nhân công"
                               VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <TextBox Grid.Column="1"
                         x:Name="SoLuongNhanCongTextBox"
                         Style="{StaticResource PillTextBox}"
                         Margin="10,0,0,0"/>
            </Grid>

            <!-- Kỹ thuật -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="Kỹ thuật"
                               VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <TextBox Grid.Column="1"
                         x:Name="KyThuatTextBox"
                         Style="{StaticResource PillTextBox}"
                         Margin="10,0,0,0"/>
            </Grid>

            <!-- An toàn lao động -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="An toàn lao động"
                               VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        CornerRadius="20" Height="40"
                        Margin="10,0,0,0" Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton x:Name="AnToanLaoDongCo"
                                     Content="Có"
                                     GroupName="AnToanLD"
                                     FontSize="13"
                                     Margin="0,0,24,0"
                                     VerticalAlignment="Center"/>
                        <RadioButton x:Name="AnToanLaoDongKhong"
                                     Content="Không"
                                     GroupName="AnToanLD"
                                     IsChecked="True"
                                     FontSize="13"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- An toàn VSMT -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="An toàn VSMT"
                               VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        CornerRadius="20" Height="40"
                        Margin="10,0,0,0" Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton x:Name="AnToanVSMTCo"
                                     Content="Có"
                                     GroupName="AnToanVSMT"
                                     FontSize="13"
                                     Margin="0,0,24,0"
                                     VerticalAlignment="Center"/>
                        <RadioButton x:Name="AnToanVSMTKhong"
                                     Content="Không"
                                     GroupName="AnToanVSMT"
                                     IsChecked="True"
                                     FontSize="13"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0" Width="210">
            <Button Content="Hủy"
                    Width="90" Height="36"
                    Background="#CCCCCC" Foreground="#333"
                    Style="{StaticResource RoundBtn}"
                    Padding="0"
                    Margin="0,0,10,0"
                    Click="Huy_Click"/>
            <Button Content="Xác nhận"
                    Width="110" Height="36"
                    Background="#3A7BD5" Foreground="White"
                    Style="{StaticResource RoundBtn}"
                    Padding="0"
                    Click="XacNhan_Click"/>
        </StackPanel>
    </Grid>
</Window>
