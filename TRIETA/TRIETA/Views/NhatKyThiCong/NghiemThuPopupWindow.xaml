<Window x:Class="Trita.Views.NhatKyThiCong.NghiemThuPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Khai báo công việc nghiệm thu"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>

        <!-- Label pill xám -->
        <Style x:Key="LabelPill" TargetType="Border">
            <Setter Property="Background"      Value="#E6E6E6"/>
            <Setter Property="BorderBrush"     Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="20"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="16,0"/>
        </Style>

        <!-- ComboBox pill — tự bo tròn, không Border ngoài -->
        <Style x:Key="PillComboBox" TargetType="ComboBox">
            <Setter Property="Height"                   Value="40"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#CCCCCC"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="14,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Pill"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False"
                                                      VerticalAlignment="Center"/>
                                    <Path Grid.Column="1"
                                          Data="M0,0 L4,5 L8,0"
                                          Stroke="#999" StrokeThickness="1.5"
                                          StrokeLineJoin="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <ToggleButton Focusable="False"
                                          Background="Transparent" BorderThickness="0"
                                          Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"/>

                            <Popup Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="White"
                                        BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="12"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#AAAAAA" BlurRadius="10"
                                                          ShadowDepth="3" Opacity="0.25"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" Margin="4"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#4A9A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding"  Value="12,8"/>
                        <Setter Property="Cursor"   Value="Hand"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="Transparent"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#EEF7EE"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#D4EDD4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="KHAI BÁO CÔNG VIỆC NGHIỆM THU"
                   FontSize="15" FontWeight="Bold"
                   Foreground="#2E4057"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <!-- Hạng mục -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="Hạng mục" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <ComboBox Grid.Column="1" x:Name="CbHangMuc"
                          Style="{StaticResource PillComboBox}"
                          Margin="10,0,0,0"
                          SelectionChanged="CbHangMuc_SelectionChanged"/>
            </Grid>

            <!-- Tên công việc -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="Tên công việc" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <ComboBox Grid.Column="1" x:Name="CbCongViec"
                          Style="{StaticResource PillComboBox}"
                          Margin="10,0,0,0"
                          SelectionChanged="CbCongViec_SelectionChanged"/>
            </Grid>

            <!-- Lý trình: hiển thị + nút mở picker -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="Lý trình" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>

                <!-- Pill hiển thị lý trình đã chọn (read-only) -->
                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        CornerRadius="20" Height="40"
                        Margin="10,0,6,0" Padding="14,0">
                    <TextBlock x:Name="TxtLyTrinhChon"
                               Text="-- Chọn lý trình --"
                               Foreground="Gray"
                               FontSize="13" FontStyle="Italic"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <!-- Nút mở picker -->
                <Button Grid.Column="2"
                        x:Name="BtnChonLyTrinh"
                        Width="36" Height="36"
                        Background="#2E7D32"
                        Foreground="White"
                        FontSize="16"
                        Style="{StaticResource RoundBtn}"
                        Padding="0"
                        ToolTip="Chọn lý trình"
                        Click="BtnChonLyTrinh_Click">
                    <TextBlock Text="…" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Giờ - phút -->
            <Grid Margin="0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource LabelPill}">
                    <TextBlock Text="Giờ - Phút" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13"/>
                </Border>
                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        CornerRadius="20" Height="40"
                        Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0">
                        <TextBox x:Name="TxtGio" Width="40"
                                 Background="Transparent"
                                 BorderThickness="0,0,1,0" BorderBrush="#CCCCCC"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 FontSize="13" MaxLength="2" Text="08"/>
                        <TextBlock Text=" : " VerticalAlignment="Center"
                                   FontSize="15" FontWeight="Bold" Foreground="#666"/>
                        <TextBox x:Name="TxtPhut" Width="40"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 FontSize="13" MaxLength="2" Text="00"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy" Width="90" Height="36"
                    Background="#CCCCCC" Foreground="#333"
                    Style="{StaticResource RoundBtn}"
                    Padding="0" Margin="0,0,10,0"
                    Click="Huy_Click"/>
            <Button Content="Xác nhận" Width="110" Height="36"
                    Background="#2E7D32" Foreground="White"
                    Style="{StaticResource RoundBtn}"
                    Padding="0"
                    Click="XacNhan_Click"/>
        </StackPanel>
    </Grid>
</Window>
