<UserControl x:Class="Trita.Views.BangPhanBo.BangPhanBoVatTuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ===== CỘT TRÁI - DANH SÁCH VẬT TƯ ===== -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="20"
                Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="DANH SÁCH VẬT TƯ"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="0,0,0,10"
                           TextAlignment="Center"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DanhSachVatTuPanel">
                        <!-- Danh sách vật tư sẽ được tạo động -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ===== CỘT GIỮA - BẢNG PHÂN BỔ ===== -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="20"
                Margin="16,0"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tiêu đề động -->
                <TextBlock x:Name="TitleTextBlock"
                           Grid.Row="0"
                           Text="VẬT TƯ"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,20"/>

                <!-- Đơn vị -->
                <TextBlock x:Name="DonViTextBlock"
                           Grid.Row="1"
                           FontSize="14"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Foreground="#666666"/>

                <!-- Bảng dữ liệu -->
                <Border Grid.Row="2"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0"
                              Background="#E6F2FF">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="STT"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"/>
                            <Border Grid.Column="0"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,0,1,0"/>

                            <TextBlock Grid.Column="1"
                                       Text="TÊN CÔNG TÁC"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"/>
                            <Border Grid.Column="1"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,0,1,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="LÝ TRÌNH"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"/>
                            <Border Grid.Column="2"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,0,1,0"/>

                            <TextBlock Grid.Column="3"
                                       Text="KHỐI LƯỢNG ĐÃ SỬ DỤNG"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Border Grid.Column="3"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,0,1,0"/>

                            <TextBlock Grid.Column="4"
                                       Text="KHỐI LƯỢNG TỒN DƯ"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="BangPhanBoPanel">
                                <!-- Dữ liệu sẽ được tạo động -->
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer tổng -->
                        <Grid Grid.Row="2"
                              Background="#F0F0F0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,1,0,0"/>
                            <Border Grid.Column="1"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,1,1,0"/>
                            <Border Grid.Column="2"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,1,1,0"/>
                            <Border Grid.Column="3"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,1,1,0"/>
                            <Border Grid.Column="4"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,1,0,0"/>

                            <TextBlock Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="Còn lại"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"/>

                            <TextBlock x:Name="TongKhoiLuongTextBlock"
                                       Grid.Column="4"
                                       FontWeight="Bold"
                                       Padding="10"
                                       TextAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== CỘT PHẢI ===== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Bảng thống kê lô hàng -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="Black"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="15"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Khối lượng theo lô"
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,10"
                               TextAlignment="Center"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="200">
                        <StackPanel x:Name="ThongKeLoPanel">
                            <!-- Thống kê lô sẽ được tạo động -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Biểu đồ Donut -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="Black"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="TỈ LỆ SỬ DỤNG VẬT TƯ"
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,10"
                               TextAlignment="Center"/>

                    <Canvas x:Name="DonutCanvas"
                            Grid.Row="1"
                            Width="240"
                            Height="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>