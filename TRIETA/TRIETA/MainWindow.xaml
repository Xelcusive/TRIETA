<Window x:Class="Trita.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vattu="clr-namespace:Trita.Views.VatTu"
        xmlns:bangphanbo="clr-namespace:Trita.Views.BangPhanBo"
        Title="TRITA"
        Width="1450"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5E6D3"
        WindowStyle="None"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <!-- TITLE BAR -->
            <RowDefinition Height="42"/>
            <!-- TAB BAR -->
            <RowDefinition Height="60"/>
            <!-- RIBBON TOOLS -->
            <RowDefinition Height="*"/>
            <!-- CONTENT -->
        </Grid.RowDefinitions>

        <!-- ================= TITLE BAR ================= -->
        <Border Grid.Row="0"
                Background="#E63C31"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="TRITA- [Tên dự án]"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="─" 
                            Width="45" 
                            Height="32" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="16"
                            Click="Minimize_Click"
                            Cursor="Hand"/>
                    <Button Content="□" 
                            Width="45" 
                            Height="32" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="14"
                            Click="Maximize_Click"
                            Cursor="Hand"/>
                    <Button Content="✕" 
                            Width="45" 
                            Height="32" 
                            Background="#D32F2F" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="16"
                            Click="Close_Click"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= TAB BAR ================= -->
        <Border Grid.Row="1" Background="#B83228">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0">

                <Border Background="#E0E0E0"
                        Height="32"
                        CornerRadius="8,8,0,0"
                        Padding="20,8"
                        Margin="2,0">
                    <TextBlock Text="Thông tin" 
                               VerticalAlignment="Center"
                               FontWeight="Medium"/>
                </Border>

                <Border Background="White"
                        Height="32"
                        CornerRadius="8,8,0,0"
                        Padding="20,8"
                        Margin="2,0">
                    <TextBlock Text="Vật tư" 
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>
                </Border>

                <Border Background="#E0E0E0"
                        Height="32"
                        CornerRadius="8,8,0,0"
                        Padding="20,8"
                        Margin="2,0">
                    <TextBlock Text="Nhân lực" 
                               VerticalAlignment="Center"
                               FontWeight="Medium"/>
                </Border>

                <Border Background="#E0E0E0"
                        Height="32"
                        CornerRadius="8,8,0,0"
                        Padding="20,8"
                        Margin="2,0">
                    <TextBlock Text="Máy móc" 
                               VerticalAlignment="Center"
                               FontWeight="Medium"/>
                </Border>

                <Border Background="#E0E0E0"
                        Height="32"
                        CornerRadius="8,8,0,0"
                        Padding="20,8"
                        Margin="2,0">
                    <TextBlock Text="Nhật ký thi công" 
                               VerticalAlignment="Center"
                               FontWeight="Medium"/>
                </Border>

                <Border Background="#E0E0E0"
                        Height="32"
                        CornerRadius="8,8,0,0"
                        Padding="20,8"
                        Margin="2,0">
                    <TextBlock Text="Biên bản" 
                               VerticalAlignment="Center"
                               FontWeight="Medium"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ================= RIBBON TOOLS ================= -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1">
            <Grid Margin="15,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Checkbox group -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,15,0">
                    <CheckBox x:Name="DauVaoVatTuCheckBox" 
                              Content="Đầu vào vật tư"
                              FontSize="11"
                              Margin="0,2"
                              VerticalAlignment="Center"/>
                    <CheckBox x:Name="BangPhanBoVatTuCheckBox" 
                              Content="Bảng phân bổ vật tư"
                              FontSize="11"
                              Margin="0,2"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="1" 
                        Width="1" 
                        Background="#CCCCCC" 
                        Margin="5,0"/>

                <!-- Tool buttons -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            Margin="15,0">

                    <!-- Xóa vật tư - Icon SVG phẳng -->
                    <Button Click="XoaVatTu_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="5"
                            Margin="0,0,10,0"
                            ToolTip="Xóa vật tư">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Viewbox Width="28" Height="28" Margin="0,0,0,1">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M6,19 C6,20.1 6.9,21 8,21 L16,21 C17.1,21 18,20.1 18,19 L18,7 L6,7 L6,19 Z M19,4 L15.5,4 L14.5,3 L9.5,3 L8.5,4 L5,4 L5,6 L19,6 L19,4 Z"
                                          Fill="#424242"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Xóa vật tư" 
                                       FontSize="9" 
                                       HorizontalAlignment="Center"
                                       Foreground="#424242"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Search -->
                <StackPanel Grid.Column="3" 
                            Orientation="Horizontal" 
                            Margin="15,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="🔍" 
                               FontSize="16" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Tìm kiếm" 
                               FontSize="12" 
                               VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ================= CONTENT ================= -->
        <ContentControl x:Name="MainContent"
                        Grid.Row="3">
            <vattu:VatTuView x:Name="VatTuViewControl"/>
        </ContentControl>
    </Grid>
</Window>